# Local mise overrides and generated local lockfiles stay machine-specific.
mise.local.toml
mise.*.local.toml
mise.local.lock
mise.*.local.lock

# Local environment and editor state.
.env
.env.*
!.env.example
.DS_Store
.vscode/
.idea/

