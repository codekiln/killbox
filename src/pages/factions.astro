---
import BaseLayout from "../layouts/BaseLayout.astro";
import { factions } from "../content/platform";
---

<BaseLayout title="Killbox Faction Previews" description="Faction visual and gameplay previews for Killbox themes.">
  <section class="compact-page">
    <div class="section-frame page-title">
      <p class="eyebrow">Faction Previews</p>
      <h1>Factions</h1>
      <p class="lede">Faction entries capture ownership colors, gameplay role, linked themes, and combat readability notes.</p>
    </div>
    <div class="section-frame grid two">
      {factions.map((faction) => (
        <article class="card">
          <div class="card-body">
            <p class="eyebrow">{faction.id}</p>
            <h2>{faction.name}</h2>
            <p>{faction.role}</p>
            <p>{faction.combatRead}</p>
            <div class="swatch-row">
              {faction.colors.map((color) => <span class="swatch" style={`background:${color}`}></span>)}
            </div>
            <div class="tag-row">
              {faction.linkedThemes.map((theme) => <span class="tag">{theme}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
