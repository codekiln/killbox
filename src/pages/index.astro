---
import GameSurface from "../components/GameSurface.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  assets,
  designTokenGroups,
  platformRoutes,
  renderingExperiments,
  themes,
  validatePlatformContent
} from "../content/platform";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const hrefWithBase = (href: string) => `${base}${href}`;
const validationIssues = validatePlatformContent();
---

<BaseLayout title="Killbox Game Platform" description="Playable Killbox builds, theme previews, asset catalogs, design tokens, and runtime validation.">
  <section class="hero">
    <div class="section-frame hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Playable build + living game design system</p>
        <h1>Killbox</h1>
        <p class="lede">
          A browser-first tower defense platform where the Phaser prototype, biome themes,
          generated asset metadata, rendering experiments, and gameplay docs live in one static Astro site.
        </p>
        <div class="hero-actions">
          <a class="button-link" href={hrefWithBase("/play/")}>Open playable route</a>
          <a class="button-link" href={hrefWithBase("/design-system/")}>Inspect design system</a>
        </div>
        <div class="route-strip">
          {platformRoutes.map((route) => (
            <a class="route-chip" href={hrefWithBase(route.href)}>
              <strong>{route.label}</strong>
              <span>{route.summary}</span>
            </a>
          ))}
        </div>
      </div>
      <GameSurface />
    </div>
  </section>

  <section class="surface-band">
    <div class="section-frame">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Worldbuilding Systems</p>
          <h2>Theme Manifests</h2>
        </div>
        <p class="small-copy">Biomes, factions, UI themes, FX, audio direction, gameplay modifiers, and asset lineage are typed shared content.</p>
      </div>
      <div class="grid two">
        {themes.map((theme) => (
          <article class="card">
            <div class="visual-map"></div>
            <div class="card-body">
              <p class="eyebrow">{theme.biome}</p>
              <h3>{theme.name}</h3>
              <p>{theme.lineage}</p>
              <div class="swatch-row">
                {theme.palette.map((color) => <span class="swatch" style={`background:${color}`}></span>)}
              </div>
              <div class="tag-row">
                {theme.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="surface-band">
    <div class="section-frame grid three">
      <article class="card">
        <div class="card-body">
          <p class="eyebrow">Design Tokens</p>
          <h3>{designTokenGroups.length} token groups</h3>
          <p>Color, type, and shape rules support static docs, HUD work, and future theme adapters.</p>
        </div>
      </article>
      <article class="card">
        <div class="card-body">
          <p class="eyebrow">Asset Pipeline</p>
          <h3>{assets.length} catalog entries</h3>
          <p>Generated-art placeholders, atlas metadata, lineage notes, and runtime suitability status render statically.</p>
        </div>
      </article>
      <article class="card">
        <div class="card-body">
          <p class="eyebrow">Runtime Validation</p>
          <h3>{validationIssues.length === 0 ? "content passes" : `${validationIssues.length} issues`}</h3>
          <p>{renderingExperiments.length} rendering experiments and manifest checks keep gameplay readability visible.</p>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
