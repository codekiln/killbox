---
import BaseLayout from "../layouts/BaseLayout.astro";
import { assets, validatePlatformContent } from "../content/platform";

const statusClass = (status: string) => `status-pill status-${status}`;
const validationIssues = validatePlatformContent();
---

<BaseLayout title="Killbox Asset Catalog" description="Generated asset previews, atlas metadata, lineage, and validation reports.">
  <section class="compact-page">
    <div class="section-frame page-title">
      <p class="eyebrow">Asset Pipeline Visibility</p>
      <h1>Asset Catalog</h1>
      <p class="lede">Generated asset metadata, atlas inspection notes, lineage, theme association, and validation reports are rendered without a backend.</p>
    </div>
    <div class="section-frame grid two">
      {assets.map((asset) => (
        <article class="card">
          <div class="card-body">
            <p class="eyebrow">{asset.type} · {asset.themeId}</p>
            <h2>{asset.name}</h2>
            <p>{asset.lineage}</p>
            <span class={statusClass(asset.validation)}>{asset.validation}</span>
            <div class="asset-row"><strong>Source</strong><span>{asset.source}</span></div>
            <div class="asset-row"><strong>Runtime use</strong><span>{asset.runtimeUse}</span></div>
            {asset.atlas && (
              <>
                <div class="asset-row"><strong>Atlas</strong><span>{asset.atlas.id}</span></div>
                <div class="asset-row"><strong>Frames</strong><span>{asset.atlas.frameCount} · {asset.atlas.dimensions}</span></div>
                <div class="asset-row"><strong>Packing</strong><span>{asset.atlas.packingNotes}</span></div>
              </>
            )}
          </div>
        </article>
      ))}
    </div>
    <div class="section-frame surface-band">
      <div class="card">
        <div class="card-body">
          <p class="eyebrow">Validation Report</p>
          <h2>{validationIssues.length === 0 ? "All static content checks pass" : "Validation issues"}</h2>
          <p>{validationIssues.length === 0 ? "Route, theme, faction, asset, and atlas references are internally consistent." : validationIssues.join(" ")}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
