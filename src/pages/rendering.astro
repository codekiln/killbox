---
import BaseLayout from "../layouts/BaseLayout.astro";
import { renderingExperiments } from "../content/platform";

const statusClass = (status: string) => `status-pill status-${status}`;
---

<BaseLayout title="Killbox Rendering Sandbox" description="Rendering experiments for shaders, particles, FX, and gameplay readability.">
  <section class="compact-page">
    <div class="section-frame page-title">
      <p class="eyebrow">Rendering Sandbox</p>
      <h1>Rendering</h1>
      <p class="lede">Static experiment previews track shader, particle, lighting, environment, and readability ideas before they graduate into runtime code.</p>
    </div>
    <div class="section-frame grid three">
      {renderingExperiments.map((experiment) => (
        <article class="card">
          <div class="visual-map"></div>
          <div class="card-body">
            <p class="eyebrow">{experiment.category}</p>
            <h2>{experiment.name}</h2>
            <p>{experiment.summary}</p>
            <span class={statusClass(experiment.status)}>{experiment.status}</span>
            <p class="small-copy">{experiment.validation}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
