---
import BaseLayout from "../layouts/BaseLayout.astro";
import { themes } from "../content/platform";

const statusClass = (status: string) => `status-pill status-${status}`;
---

<BaseLayout title="Killbox Theme Gallery" description="Biome, faction, theme, and rendering manifest previews for Killbox.">
  <section class="compact-page">
    <div class="section-frame page-title">
      <p class="eyebrow">Biome and Theme Gallery</p>
      <h1>Themes</h1>
      <p class="lede">Theme manifests define swappable world presentation, UI direction, audio direction, gameplay modifiers, lineage, and readability constraints.</p>
    </div>
    <div class="section-frame grid two">
      {themes.map((theme) => (
        <article class="card">
          <div class="visual-map"></div>
          <div class="card-body">
            <p class="eyebrow">{theme.id}</p>
            <h2>{theme.name}</h2>
            <p>{theme.lineage}</p>
            <div class="swatch-row">
              {theme.palette.map((color) => <span class="swatch" style={`background:${color}`}></span>)}
            </div>
            <div class="asset-row"><strong>Faction</strong><span>{theme.factionId}</span></div>
            <div class="asset-row"><strong>Enemies</strong><span>{theme.enemyTheme}</span></div>
            <div class="asset-row"><strong>Tileset</strong><span>{theme.tileset}</span></div>
            <div class="asset-row"><strong>FX</strong><span>{theme.environmentFx.join(", ")}</span></div>
            <div class="asset-row"><strong>Modifiers</strong><span>{theme.gameplayModifiers.join(", ")}</span></div>
            <div class="status-row">
              <span class={statusClass(theme.readability.contrast)}>contrast {theme.readability.contrast}</span>
              <span class={statusClass(theme.readability.laneClarity)}>lanes {theme.readability.laneClarity}</span>
              <span class={statusClass(theme.readability.towerEnemyDistinction)}>silhouettes {theme.readability.towerEnemyDistinction}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
