---
import BaseLayout from "../layouts/BaseLayout.astro";
import { designTokenGroups } from "../content/platform";
---

<BaseLayout title="Killbox Design System" description="Visual tokens, typography, components, and readability validation for Killbox.">
  <section class="compact-page">
    <div class="section-frame page-title">
      <p class="eyebrow">Living Design System</p>
      <h1>Design System</h1>
      <p class="lede">Tokens and component guidance keep the game platform readable across theme previews, HUD surfaces, documentation, and future runtime UI.</p>
    </div>
    <div class="section-frame grid three">
      {designTokenGroups.map((group) => (
        <article class="card">
          <div class="card-body">
            <p class="eyebrow">{group.id}</p>
            <h2>{group.label}</h2>
            <p>{group.description}</p>
            <div>
              {group.tokens.map((token) => (
                <div class="token-row">
                  <strong>{token.name}</strong>
                  <span><code>{token.value}</code><br /><span class="token-usage">{token.usage}</span></span>
                </div>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
