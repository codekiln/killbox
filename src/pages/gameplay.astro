---
import BaseLayout from "../layouts/BaseLayout.astro";
import { gameplayMechanics } from "../content/platform";
---

<BaseLayout title="Killbox Gameplay Documentation" description="Gameplay mechanic documentation and runtime validation notes.">
  <section class="compact-page">
    <div class="section-frame page-title">
      <p class="eyebrow">Gameplay Mechanic Documentation</p>
      <h1>Gameplay</h1>
      <p class="lede">Mechanics are documented with both player-readable behavior and system-readable validation hooks.</p>
    </div>
    <div class="section-frame grid two">
      {gameplayMechanics.map((mechanic) => (
        <article class="card">
          <div class="card-body">
            <p class="eyebrow">{mechanic.id}</p>
            <h2>{mechanic.name}</h2>
            <div class="mechanic-row"><strong>Player read</strong><span>{mechanic.playerRead}</span></div>
            <div class="mechanic-row"><strong>System read</strong><span>{mechanic.systemRead}</span></div>
            <div class="mechanic-row"><strong>Validation</strong><span>{mechanic.validation}</span></div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
