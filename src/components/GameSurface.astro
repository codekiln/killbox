---
import { getDeploymentVersion } from "../deployment";

const deploymentVersion = getDeploymentVersion();
---

<div id="app" data-killbox-version={deploymentVersion}>
  <div id="game-shell" aria-label="Playable Killbox prototype">
    <div id="game-root"></div>
    <p id="deployment-version" data-killbox-version={deploymentVersion}>Version {deploymentVersion}</p>
    <output id="semantic-state" aria-live="polite">Loading mission state...</output>
  </div>
</div>

<script>
  import { mountKillboxGame } from "../runtime/phaserApp";

  const root = document.querySelector<HTMLElement>("#game-root");
  if (root && root.dataset.killboxMounted !== "true") {
    root.dataset.killboxMounted = "true";
    const runtime = mountKillboxGame({ parent: root });
    window.addEventListener("beforeunload", () => runtime.destroy(), { once: true });
  }
</script>
