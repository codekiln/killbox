---
import "../styles.css";
import { getDeploymentVersion } from "../deployment";
import { platformRoutes } from "../content/platform";

interface Props {
  title: string;
  description: string;
  shellClass?: string;
}

const { title, description, shellClass = "" } = Astro.props;
const deploymentVersion = getDeploymentVersion();
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const hrefWithBase = (href: string) => `${base}${href}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <div class:list={["site-shell", shellClass]}>
      <header class="site-header">
        <nav class="nav-frame" aria-label="Primary">
          <a class="brand" href={hrefWithBase("/")}>
            <strong>Killbox</strong>
            <span>{deploymentVersion}</span>
          </a>
          <div class="nav-links">
            {platformRoutes.map((route) => <a href={hrefWithBase(route.href)}>{route.label}</a>)}
          </div>
          <details class="mobile-menu">
            <summary aria-label="Open navigation">
              <span aria-hidden="true"></span>
              <span aria-hidden="true"></span>
              <span aria-hidden="true"></span>
            </summary>
            <div class="mobile-menu-panel">
              {platformRoutes.map((route) => <a href={hrefWithBase(route.href)}>{route.label}</a>)}
            </div>
          </details>
        </nav>
      </header>
      <main class="page-main">
        <slot />
      </main>
    </div>
  </body>
</html>
