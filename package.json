{
  "name": "killbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "tsc --noEmit && astro build",
    "preview": "astro preview --host 127.0.0.1",
    "lint": "tsc --noEmit --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e:local",
    "test:e2e:local": "npm run build && playwright test",
    "test:e2e:public": "playwright test",
    "spec-check": "openspec validate --all --strict --no-interactive",
    "check": "npm run lint && npm run test && npm run build && npm run test:e2e:public && npm run spec-check"
  },
  "dependencies": {
    "phaser": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "latest",
    "astro": "^6.3.7",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
